{
  "name": "@th3mouk/maestro",
  "version": "0.1.1",
  "description": "Maestro: partial or complete multi-repository workspaces for AI-assisted engineering environments.",
  "keywords": [
    "ai",
    "automation",
    "claude-code",
    "cli",
    "codex",
    "devcontainer",
    "devtools",
    "git",
    "github-actions",
    "multi-repo",
    "opencode",
    "orchestration",
    "platform-engineering",
    "repository-management",
    "sparse-checkout",
    "typescript",
    "workspace",
    "worktree"
  ],
  "homepage": "https://github.com/Th3Mouk/maestro",
  "bugs": {
    "url": "https://github.com/Th3Mouk/maestro/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Th3Mouk/maestro.git"
  },
  "bin": {
    "maestro": "./bin/maestro.js"
  },
  "files": [
    "bin/**",
    "dist/**",
    "docs/architecture/**",
    "docs/assets/**",
    "docs/cli/**",
    "docs/manifests/**",
    "examples/**",
    "framework-packs/**",
    "npm-shrinkwrap.json",
    "README.md",
    "LICENSE",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "assets:banner": "node scripts/generate-banner.js",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/prepare-bin.mjs",
    "lint": "oxlint --config .oxlintrc.json --deny-warnings src tests scripts",
    "lint:fix": "oxlint --config .oxlintrc.json --fix --fix-suggestions src tests scripts",
    "format": "oxfmt --config .oxfmtrc.json --write .",
    "format:check": "oxfmt --config .oxfmtrc.json --check .",
    "knip": "knip --cache",
    "sync:npm-shrinkwrap": "node scripts/sync-npm-shrinkwrap.mjs --write",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:audit-prod": "pnpm audit --prod",
    "test:npm-shrinkwrap": "node scripts/sync-npm-shrinkwrap.mjs --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "pnpm test:coverage",
    "test:smoke": "node bin/maestro.js --help",
    "pack:artifact": "pnpm pack --pack-destination .artifacts",
    "test:pack": "rm -rf .artifacts && pnpm pack:artifact && node scripts/verify-packed-artifact.mjs",
    "test:release-provenance": "node scripts/verify-release-provenance.mjs",
    "test:runtime-dependencies": "node scripts/verify-runtime-dependencies.mjs",
    "check": "pnpm sync:npm-shrinkwrap && pnpm knip && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:audit-prod && pnpm test:npm-shrinkwrap && pnpm build && pnpm test && pnpm test:runtime-dependencies && pnpm test:smoke && pnpm test:pack && pnpm test:release-provenance",
    "prepack": "pnpm sync:npm-shrinkwrap && pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "deepmerge": "^4.3.1",
    "execa": "^9.6.0",
    "picomatch": "^4.0.2",
    "proper-lockfile": "^4.1.2",
    "safe-regex2": "^5.0.0",
    "semver": "^7.7.2",
    "shell-quote": "^1.8.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.7.0",
    "@types/shell-quote": "^1.7.5",
    "@vitest/coverage-v8": "^4.1.2",
    "knip": "^6.0.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.56.0",
    "satori": "^0.26.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.33.0"
}
